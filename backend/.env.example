# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API

# Project URL (same for both server and client)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# anon/public key — safe to expose in browser
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role key — NEVER expose this in the browser / commit to git
# Used only by server-side code (api/chat.ts, seed.ts, mock-sensor.ts)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Vite needs the project ID for the Supabase integration
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# ─── Lovable AI Gateway ──────────────────────────────────────────────────────
# Get from: https://lovable.dev → Settings → API Keys
# Routes AI calls through Lovable's gateway (Gemini 3 Flash)
LOVABLE_API_KEY=lv_...
